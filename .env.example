# Token del bot — Portal de Desarrolladores > Applications > Tu app > Bot > Token
DISCORD_TOKEN=

# ID del canal de voz que actúa como trigger para crear salas
# Cuando alguien entra aquí, Flynn crea un canal temporal para él
VOICE_TRIGGER_ID=

# ID de la categoría donde se crearán los canales temporales
CATEGORY_ID=

# ID del rol "verificado" — usado por !private y !unprivate
VERIFIED_ROLE_ID=
